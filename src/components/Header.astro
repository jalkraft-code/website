---
const { class: className = '' } = Astro.props as { class?: string };
const links = [
  { href: '/', label: 'Home' },
  { href: '/updates', label: 'Updates' },
  { href: '/projects', label: 'Projects' },
  { href: '/photos', label: 'Photos' },
  { href: '/about', label: 'About' },
];
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class={`site-header ${className}`}>
  <div class="site-header-inner">
    <a class="site-title" href="/">Jake</a>
    <nav class="site-nav" aria-label="Primary">
      {links.map((l) => {
        const isCurrent =
          l.href === '/' ? path === '/' : path === l.href || path.startsWith(l.href + '/');
        return (
          <a href={l.href} aria-current={isCurrent ? 'page' : undefined}>{l.label}</a>
        );
      })}
    </nav>
  </div>
</header>
