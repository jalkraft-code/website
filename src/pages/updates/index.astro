---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../components/Layout.astro';
import { imagesForAlbum } from '../../lib/album-photos';

const updates = (await getCollection('updates', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const items = updates.map((u) => ({ entry: u, photos: imagesForAlbum(u.slug) }));
---
<Layout title="Updates" description="Life updates from Jake.">
  <h1>Updates</h1>
  <p class="intro">What I've been up to, in reverse chronological order.</p>

  {items.length === 0 ? (
    <p class="muted">No updates yet.</p>
  ) : (
    <ul class="post-list">
      {items.map(({ entry: u, photos }) => (
        <li>
          <h3><a href={`/updates/${u.slug}/`}>{u.data.title}</a></h3>
          <p class="post-meta">{dateFmt.format(u.data.date)}</p>
          {u.data.summary && <p>{u.data.summary}</p>}
          {photos.length > 0 && (
            <div class="thumb-grid">
              {photos.map((img) => (
                <a href={`/updates/${u.slug}/`} aria-label={`Open post: ${u.data.title}`}>
                  <Image src={img} alt="" widths={[160, 320]} sizes="160px" />
                </a>
              ))}
            </div>
          )}
        </li>
      ))}
    </ul>
  )}
</Layout>
