---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../components/Layout.astro';
import { imagesForAlbum } from '../../lib/album-photos';

export async function getStaticPaths() {
  const entries = await getCollection('albums', ({ data }) => !data.draft);
  return entries.map((entry) => ({ params: { album: entry.slug }, props: { entry } }));
}

type Props = { entry: CollectionEntry<'albums'> };
const { entry } = Astro.props as Props;
const { Content } = await entry.render();
const dateFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Prefer explicit photos[] from frontmatter (for captions/ordering); otherwise auto-discover
// every image in src/assets/photos/<slug>/ so just dropping files into the folder works.
const autoImages = imagesForAlbum(entry.slug);
const photos = entry.data.photos.length > 0
  ? entry.data.photos
  : autoImages.map((src) => ({ src, alt: entry.data.title, caption: undefined }));
---
<Layout title={entry.data.title} description={entry.data.description} wide>
  <h1>{entry.data.title}</h1>
  <p class="post-meta">{dateFmt.format(entry.data.date)}</p>
  {entry.data.description && <p class="intro">{entry.data.description}</p>}

  <Content />

  {photos.length === 0 ? (
    <p class="muted">No photos in this album yet. Drop images into <code>src/assets/photos/{entry.slug}/</code>.</p>
  ) : (
    <div class="album-photos">
      {photos.map((p) => (
        <figure>
          <a href={p.src.src} target="_blank" rel="noopener">
            <Image src={p.src} alt={p.alt} widths={[480, 800, 1200, 1600]} sizes="(min-width: 720px) 680px, 100vw" />
          </a>
          {p.caption && <figcaption>{p.caption}</figcaption>}
        </figure>
      ))}
    </div>
  )}

  <hr />
  <p><a href="/photos">← All albums</a></p>
</Layout>
