---
import { Image } from 'astro:assets';
import Layout from '../../components/Layout.astro';
import { listAlbums } from '../../lib/album-photos';

export async function getStaticPaths() {
  return listAlbums().map((a) => ({ params: { album: a.slug }, props: { album: a } }));
}

type Props = { album: { slug: string; title: string; photos: import('astro').ImageMetadata[] } };
const { album } = Astro.props as Props;
---
<Layout title={album.title} description={`Photos from ${album.title}`} wide>
  <h1>{album.title}</h1>

  {album.photos.length === 0 ? (
    <p class="muted">No photos in this album yet. Drop images into <code>src/assets/photos/{album.slug}/</code>.</p>
  ) : (
    <div class="album-photos">
      {album.photos.map((img) => (
        <figure>
          <a href={img.src} target="_blank" rel="noopener">
            <Image src={img} alt={album.title} widths={[480, 800, 1200, 1600]} sizes="(min-width: 720px) 680px, 100vw" />
          </a>
        </figure>
      ))}
    </div>
  )}

  <hr />
  <p><a href="/photos">← All albums</a></p>
</Layout>
