---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../components/Layout.astro';

const albums = (await getCollection('albums', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const dateFmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long' });
---
<Layout title="Photos" description="Photo albums by Jake." wide>
  <h1>Photos</h1>
  <p class="intro">Moments from trips, projects, and ordinary days.</p>

  {albums.length === 0 ? (
    <p class="muted">No albums yet.</p>
  ) : (
    <div class="photo-grid">
      {albums.map((a) => (
        <a href={`/photos/${a.slug}/`} style="border:none">
          <figure>
            <Image src={a.data.cover} alt={a.data.title} widths={[320, 480, 640]} sizes="(min-width: 720px) 320px, 50vw" />
            <figcaption>
              <strong style="color:var(--fg)">{a.data.title}</strong>
              <br />{dateFmt.format(a.data.date)}
            </figcaption>
          </figure>
        </a>
      ))}
    </div>
  )}
</Layout>
