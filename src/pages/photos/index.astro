---
import { Image } from 'astro:assets';
import Layout from '../../components/Layout.astro';
import { listAlbums } from '../../lib/album-photos';

const albums = listAlbums();
---
<Layout title="Photos" description="Photo albums by Jake." wide>
  <h1>Photos</h1>
  <p class="intro">Moments from trips, projects, and ordinary days.</p>

  {albums.length === 0 ? (
    <p class="muted">No albums yet.</p>
  ) : (
    <div class="photo-grid">
      {albums.map(({ slug, title, photos }) => (
        <a href={`/photos/${slug}/`} style="border:none">
          <figure>
            {photos[0] && (
              <Image src={photos[0]} alt={title} widths={[320, 480, 640]} sizes="(min-width: 720px) 320px, 50vw" />
            )}
            <figcaption>
              <strong style="color:var(--fg)">{title}</strong>
              {photos.length > 0 && <span class="muted"> · {photos.length} photo{photos.length === 1 ? '' : 's'}</span>}
            </figcaption>
          </figure>
        </a>
      ))}
    </div>
  )}
</Layout>
